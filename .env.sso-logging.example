# SSO Logging Configuration
# ================================

# Enable/Disable logging categories
SSO_LOG_AUTH_FLOW=true
SSO_LOG_TOKEN_MGMT=true
SSO_LOG_SECURITY_EVENTS=true
SSO_LOG_PERFORMANCE=true

# Log levels for each category
SSO_LOG_AUTH_FLOW_LEVEL=info
SSO_LOG_TOKEN_MGMT_LEVEL=info
SSO_LOG_SECURITY_EVENTS_LEVEL=warning
SSO_LOG_PERFORMANCE_LEVEL=info

# Performance monitoring
SSO_SLOW_THRESHOLD_MS=2000
SSO_TRACK_MEMORY_USAGE=true
SSO_TRACK_DB_QUERIES=true

# Security settings
SSO_RATE_LIMIT_THRESHOLD=30
SSO_SUSPICIOUS_UA_DETECTION=true
SSO_LOG_FAILED_ATTEMPTS=true

# Token logging
SSO_LOG_TOKEN_PREVIEW_LENGTH=20
SSO_LOG_INCLUDE_PAYLOAD_DETAILS=true

# Data retention (in days)
SSO_LOG_AUTH_FLOW_RETENTION=30
SSO_LOG_TOKEN_MGMT_RETENTION=90
SSO_LOG_SECURITY_RETENTION=365
SSO_LOG_PERFORMANCE_RETENTION=7

# General logging settings
SSO_LOG_CHANNEL=single
SSO_LOG_SANITIZE_SENSITIVE=true
SSO_LOG_MAX_CONTEXT_SIZE=10000

# Alert thresholds
SSO_ALERT_ERROR_RATE_THRESHOLD=10
SSO_ALERT_FAILED_LOGIN_THRESHOLD=5
SSO_ALERT_PERF_THRESHOLD=5000
SSO_ALERT_SECURITY_THRESHOLD=3

# Development settings
SSO_LOG_DEBUG=false
SSO_LOG_VERBOSE_ERRORS=false
SSO_LOG_INCLUDE_FULL_REQUEST=false

# Export settings
SSO_LOG_EXPORT_ENABLED=true
SSO_LOG_MAX_EXPORT_RECORDS=10000
